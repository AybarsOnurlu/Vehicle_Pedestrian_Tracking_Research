# ============================================
# .gitignore - Vehicle & Pedestrian Tracking
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
venv/
env/
.venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Model Weights (large binary files) ---
models/pretrained/*.pt
models/pretrained/*.pth
models/trained/*.pt
models/trained/*.pth
models/exported/*.engine
models/exported/*.onnx
!models/pretrained/.gitkeep
!models/trained/.gitkeep
!models/exported/.gitkeep

# --- Datasets (large, download separately) ---
data/raw/*
!data/raw/.gitkeep
data/processed/train/images/*
data/processed/train/labels/*
data/processed/val/images/*
data/processed/val/labels/*
data/processed/test/images/*
data/processed/test/labels/*
!data/processed/train/images/.gitkeep
!data/processed/train/labels/.gitkeep
!data/processed/val/images/.gitkeep
!data/processed/val/labels/.gitkeep
!data/processed/test/images/.gitkeep
!data/processed/test/labels/.gitkeep

# --- Outputs ---
outputs/videos/*
outputs/logs/*
outputs/metrics/*
!outputs/videos/.gitkeep
!outputs/logs/.gitkeep
!outputs/metrics/.gitkeep

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Experiment Tracking ---
wandb/
mlruns/

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Misc ---
*.log
*.tmp
.env
